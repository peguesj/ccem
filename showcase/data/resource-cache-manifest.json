  "update_check_script": "#!/bin/bash\n# Usage: ./check-updates.sh\n# Checks pinned versions against npm/GitHub latest\n# Returns JSON with { resource: { pinned, latest, needs_update } }\nfor pkg in mermaid animejs @lottiefiles/lottie-player rough-notation simple-icons heroicons; do\n  latest=$(curl -s \"https://registry.npmjs.org/$pkg/latest\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('version','?'))\" 2>/dev/null)\n  echo \"$pkg: $latest\"\ndone"
